# API 配置
API_KEY=your_api_key_here
MODEL=openrouter/free
API_BASE_URL=https://openrouter.ai/api
MAX_TOKENS=100000
TIMEOUT=60
MAX_RETRIES=3

# 邮件配置（必需）
EMAIL_FROM=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_TO=recipient@example.com
EMAIL_USE_TLS=true

# 邮箱服务器和端口会根据邮箱后缀自动检测

# 新闻数量配置
MAX_TECH_NEWS=10
MAX_AI_NEWS=10
MAX_GITHUB_REPOS=10