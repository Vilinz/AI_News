# API 配置
API_KEY=your_api_key_here
MODEL=glm-4-flash
API_BASE_URL=https://open.bigmodel.cn/api/paas/v4
MAX_TOKENS=2000
TIMEOUT=60
MAX_RETRIES=3

# 邮件配置
EMAIL_FROM=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_TO=recipient@example.com
EMAIL_SERVER=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true

# 新闻数量配置
MAX_TECH_NEWS=10
MAX_AI_NEWS=10
MAX_GITHUB_REPOS=10